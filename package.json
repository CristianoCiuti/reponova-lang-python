{
  "name": "@reponova/lang-python",
  "version": "0.1.0",
  "description": "Python language support for RepoNova",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": ["dist", "grammars"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "reponova": "^0.x"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "reponova": "file:../reponova",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "web-tree-sitter": "^0.25.10"
  },
  "reponova": {
    "type": "language",
    "id": "python",
    "extensions": [".py", ".pyw"],
    "grammar": "./grammars/tree-sitter-python.wasm"
  }
}
